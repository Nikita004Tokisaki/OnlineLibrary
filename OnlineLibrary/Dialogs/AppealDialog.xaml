<Window x:Class="OnlineLibrary.Dialogs.AppealDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:OnlineLibrary.Dialogs"
        mc:Ignorable="d"
        Title="Оспаривание" Height="350" Width="400" WindowStartupLocation="CenterOwner" ResizeMode="NoResize">
    <Border Background="White" CornerRadius="10" Padding="20">
        <StackPanel>
            <TextBlock x:Name="txtTitle" FontSize="16" FontWeight="Bold" TextAlignment="Center"/>
            <TextBlock Text="Объяснение:" Margin="0,10,0,5"/>
            <TextBox x:Name="txtAppeal" Height="100" TextWrapping="Wrap" AcceptsReturn="True"/>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
                <Button x:Name="btnSubmit" Content="Отправить" Style="{StaticResource PrimaryButton}" Width="100" Click="BtnSubmit_Click"/>
                <Button x:Name="btnCancel" Content="Отмена" Style="{StaticResource DangerButton}" Width="100" Margin="10,0,0,0" Click="BtnCancel_Click"/>
            </StackPanel>
        </StackPanel>
    </Border>
</Window>
