<Window x:Class="OnlineLibrary.Dialogs.FreezeUserDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:OnlineLibrary.Dialogs"
        mc:Ignorable="d"
        Title="Заморозка" Height="280" Width="380" WindowStartupLocation="CenterOwner" ResizeMode="NoResize">
    <Border Background="White" CornerRadius="10" Padding="20">
        <StackPanel>
            <TextBlock Text="Причина заморозки:" FontWeight="Bold"/>
            <TextBox x:Name="txtReason" Height="80" TextWrapping="Wrap" AcceptsReturn="True" Margin="0,5,0,0"/>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
                <Button x:Name="btnFreeze" Content="Заморозить" Style="{StaticResource DangerButton}" Width="100" Click="BtnFreeze_Click"/>
                <Button x:Name="btnCancel" Content="Отмена" Style="{StaticResource PrimaryButton}" Width="100" Margin="10,0,0,0" Click="BtnCancel_Click"/>
            </StackPanel>
        </StackPanel>
    </Border>
</Window>
