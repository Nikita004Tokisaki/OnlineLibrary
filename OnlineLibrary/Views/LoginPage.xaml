<Page x:Class="OnlineLibrary.Views.LoginPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:OnlineLibrary.Views"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="Авторизация" Background="{StaticResource PrimaryColor}">

    <Grid VerticalAlignment="Center" HorizontalAlignment="Center" Width="380">
        <Border Background="White" CornerRadius="10" Padding="25">
            <StackPanel>
                <TextBlock Text="Онлайн библиотека" FontSize="22" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,20"/>

                <TextBlock Text="Логин" FontWeight="Bold" Margin="0,0,0,5"/>
                <TextBox x:Name="txtLogin" Height="35" Margin="0,0,0,15"/>

                <TextBlock Text="Пароль" FontWeight="Bold" Margin="0,0,0,5"/>
                <PasswordBox x:Name="txtPassword" Height="35" Margin="0,0,0,20"/>

                <Button x:Name="btnLogin" Content="Войти" Style="{StaticResource PrimaryButton}" Height="40" Margin="0,0,0,10" Click="BtnLogin_Click"/>
                <Button x:Name="btnRegister" Content="Регистрация" Background="Transparent" BorderThickness="0" Foreground="#3498DB" Cursor="Hand" Click="BtnRegister_Click"/>
            </StackPanel>
        </Border>
    </Grid>
</Page>
