<Page x:Class="OnlineLibrary.Views.RegisterPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:OnlineLibrary.Views"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="Регистрация">

    <Grid VerticalAlignment="Center" HorizontalAlignment="Center" Width="380">
        <Border Background="White" CornerRadius="10" Padding="25">
            <StackPanel>
                <TextBlock Text="Регистрация" FontSize="20" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,15"/>

                <TextBlock Text="Логин" FontWeight="Bold" Margin="0,5,0,3"/>
                <TextBox x:Name="txtLogin" Height="32"/>

                <TextBlock Text="Пароль" FontWeight="Bold" Margin="0,10,0,3"/>
                <PasswordBox x:Name="txtPassword" Height="32"/>

                <TextBlock Text="Подтверждение" FontWeight="Bold" Margin="0,10,0,3"/>
                <PasswordBox x:Name="txtConfirm" Height="32"/>

                <TextBlock Text="Email" FontWeight="Bold" Margin="0,10,0,3"/>
                <TextBox x:Name="txtEmail" Height="32"/>

                <TextBlock Text="Отображаемое имя" FontWeight="Bold" Margin="0,10,0,3"/>
                <TextBox x:Name="txtDisplayName" Height="32" Margin="0,0,0,15"/>

                <Button x:Name="btnRegister" Content="Зарегистрироваться" Style="{StaticResource PrimaryButton}" Height="38" Margin="0,0,0,10" Click="BtnRegister_Click"/>
                <Button x:Name="btnCancel" Content="Назад" Background="Transparent" BorderThickness="0" Foreground="Gray" Cursor="Hand" Click="BtnCancel_Click"/>
            </StackPanel>
        </Border>
    </Grid>
</Page>
