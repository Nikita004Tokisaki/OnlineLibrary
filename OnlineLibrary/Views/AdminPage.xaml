<Page x:Class="OnlineLibrary.Views.AdminPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:OnlineLibrary.Views"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="AdminPage">

    <Grid Margin="20">
        <TabControl>
            <TabItem Header="⚠️ Жалобы">
                <ItemsControl x:Name="complaintsList">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Background="White" Padding="15" CornerRadius="8" Margin="0,5">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock Text="{Binding TargetInfo}" FontWeight="Bold"/>
                                        <TextBlock Text="{Binding Reason}" TextWrapping="Wrap" Margin="0,10,0,0"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                                        <Button Content="Принять" Style="{StaticResource SuccessButton}" Width="80" Click="AcceptComplaint_Click" Tag="{Binding ComplaintId}"/>
                                        <Button Content="Отклонить" Style="{StaticResource DangerButton}" Width="80" Margin="5,0,0,0" Click="RejectComplaint_Click" Tag="{Binding ComplaintId}"/>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </TabItem>
            <TabItem Header="✍️ Заявки на автора">
                <ItemsControl x:Name="authorRequests">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Background="White" Padding="15" CornerRadius="8" Margin="0,5">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock Text="{Binding UserName}" FontWeight="Bold"/>
                                        <TextBlock Text="{Binding Reason}" TextWrapping="Wrap" Margin="0,10,0,0"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                                        <Button Content="Принять" Style="{StaticResource SuccessButton}" Width="80" Click="AcceptAuthor_Click" Tag="{Binding RequestId}"/>
                                        <Button Content="Отклонить" Style="{StaticResource DangerButton}" Width="80" Margin="5,0,0,0" Click="RejectAuthor_Click" Tag="{Binding RequestId}"/>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </TabItem>
            <TabItem Header="🔓 Разморозка">
                <ItemsControl x:Name="unfreezeRequests">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Background="White" Padding="15" CornerRadius="8" Margin="0,5">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock Text="{Binding UserName}" FontWeight="Bold"/>
                                        <TextBlock Text="{Binding AppealText}" TextWrapping="Wrap" Margin="0,10,0,0"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                                        <Button Content="Принять" Style="{StaticResource SuccessButton}" Width="80" Click="AcceptUnfreeze_Click" Tag="{Binding RequestId}"/>
                                        <Button Content="Отклонить" Style="{StaticResource DangerButton}" Width="80" Margin="5,0,0,0" Click="RejectUnfreeze_Click" Tag="{Binding RequestId}"/>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </TabItem>
            <TabItem Header="❄️ Замороженные">
                <ScrollViewer>
                    <StackPanel>
                        <TextBlock Text="Книги" FontWeight="Bold"/>
                        <ItemsControl x:Name="frozenBooks">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="White" Padding="10" CornerRadius="5" Margin="0,2">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="{Binding Title}"/>
                                            <Button Grid.Column="1" Content="Разморозить" Style="{StaticResource SuccessButton}" Width="100" Click="UnfreezeBook_Click" Tag="{Binding BookId}"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        <TextBlock Text="Пользователи" FontWeight="Bold" Margin="0,15,0,0"/>
                        <ItemsControl x:Name="frozenUsers">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="White" Padding="10" CornerRadius="5" Margin="0,2">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="{Binding DisplayName}"/>
                                            <Button Grid.Column="1" Content="Разморозить" Style="{StaticResource SuccessButton}" Width="100" Click="UnfreezeUser_Click" Tag="{Binding UserId}"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        <TextBlock Text="Отзывы" FontWeight="Bold" Margin="0,15,0,0"/>
                        <ItemsControl x:Name="frozenReviews">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="White" Padding="10" CornerRadius="5" Margin="0,2">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="{Binding Content}" TextWrapping="Wrap"/>
                                            <Button Grid.Column="1" Content="Разморозить" Style="{StaticResource SuccessButton}" Width="100" Click="UnfreezeReview_Click" Tag="{Binding ReviewId}"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>
            <TabItem Header="👥 Пользователи">
                <ItemsControl x:Name="usersList">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Background="White" Padding="15" CornerRadius="8" Margin="0,5">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock Text="{Binding DisplayName}" FontWeight="Bold"/>
                                        <TextBlock Text="{Binding Login}" Foreground="Gray" FontSize="12"/>
                                        <TextBlock Text="{Binding Email}" Foreground="Gray" FontSize="12"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                        <ComboBox x:Name="cmbRole" Width="120" SelectedValue="{Binding Role, Mode=OneWay}">
                                            <ComboBoxItem Tag="user">Пользователь</ComboBoxItem>
                                            <ComboBoxItem Tag="author">Автор</ComboBoxItem>
                                            <ComboBoxItem Tag="admin">Администратор</ComboBoxItem>
                                        </ComboBox>
                                        <Button Content="Сохранить" Style="{StaticResource PrimaryButton}" Width="70" Margin="5,0" Click="SaveRole_Click" Tag="{Binding UserId}"/>
                                        <Button Content="Сменить пароль" Style="{StaticResource PrimaryButton}" Width="100" Click="ChangePassword_Click" Tag="{Binding UserId}"/>
                                        <Button Content="Заморозить" Style="{StaticResource DangerButton}" Width="90" Click="FreezeUser_Click" Tag="{Binding UserId}" Visibility="{Binding FreezeBtnVis}"/>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </TabItem>
        </TabControl>
    </Grid>
</Page>
