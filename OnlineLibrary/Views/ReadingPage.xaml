<Page x:Class="OnlineLibrary.Views.ReadingPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:OnlineLibrary.Views"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="ReadingPage">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Border Background="#2C3E50" Padding="15">
            <StackPanel Orientation="Horizontal">
                <Button x:Name="btnBack" Content="← Назад" Style="{StaticResource PrimaryButton}" Width="80" Click="BtnBack_Click"/>
                <TextBlock x:Name="txtTitle" FontSize="18" FontWeight="Bold" Foreground="White" Margin="20,0,0,0" VerticalAlignment="Center"/>
            </StackPanel>
        </Border>
        <ScrollViewer Grid.Row="1" Background="White">
            <TextBlock x:Name="txtContent" FontSize="14" LineHeight="25" TextWrapping="Wrap" Margin="50,30,50,30"/>
        </ScrollViewer>
    </Grid>
</Page>
