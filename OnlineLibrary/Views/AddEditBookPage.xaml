<Page x:Class="OnlineLibrary.Views.AddEditBookPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:OnlineLibrary.Views"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="AddEditBookPage">

        <Border Background="White" Padding="25" CornerRadius="10" Margin="20">
            <StackPanel>
                <TextBlock x:Name="txtTitle" FontSize="20" FontWeight="Bold" Margin="0,0,0,20"/>
                <TextBlock Text="Название" FontWeight="Bold"/>
                <TextBox x:Name="txtBookTitle" Margin="0,5,0,15"/>
                <TextBlock Text="Описание" FontWeight="Bold"/>
                <TextBox x:Name="txtDescription" Height="80" TextWrapping="Wrap" Margin="0,5,0,15"/>
                <TextBlock Text="Жанры" FontWeight="Bold"/>
                <TextBox x:Name="txtGenres" Margin="0,5,0,15"/>
                <TextBlock Text="Путь к тексту" FontWeight="Bold"/>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBox x:Name="txtContentPath" Grid.Column="0" Margin="0,5,0,15"/>
                    <Button Grid.Column="1" Content="Обзор" Style="{StaticResource PrimaryButton}" Width="60" Margin="10,5,0,15" Click="BrowseContent_Click"/>
                </Grid>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button x:Name="btnSave" Content="Сохранить" Style="{StaticResource PrimaryButton}" Width="100" Click="BtnSave_Click"/>
                    <Button x:Name="btnCancel" Content="Отмена" Style="{StaticResource DangerButton}" Width="100" Margin="10,0,0,0" Click="BtnCancel_Click"/>
                </StackPanel>
            </StackPanel>
        </Border>
</Page>
