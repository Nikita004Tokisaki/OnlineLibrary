<Page x:Class="OnlineLibrary.Views.BookPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:OnlineLibrary.Views"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="Книга"
      Background="#F0F2F5">

    <ScrollViewer Margin="20" VerticalScrollBarVisibility="Auto">
        <StackPanel>
            <Button x:Name="btnBack" Content="← Назад" Style="{StaticResource PrimaryButton}" Width="80" Height="30" HorizontalAlignment="Left" Margin="0,0,0,15" Click="BtnBack_Click"/>

            <Border Background="White" CornerRadius="10" Padding="20" Margin="0,0,0,15">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="120"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock x:Name="imgCover" Text="📖" FontSize="60" TextAlignment="Center"/>
                    <StackPanel Grid.Column="1" Margin="15,0,0,0">
                        <TextBlock x:Name="txtTitle" FontSize="20" FontWeight="Bold" TextWrapping="Wrap"/>
                        <TextBlock x:Name="txtAuthor" FontSize="13" Foreground="Gray" Margin="0,5,0,5"/>
                        <TextBlock x:Name="txtGenres" FontSize="12" Foreground="Gray"/>
                        <TextBlock x:Name="txtRating" Text="★ 0.0" Foreground="Gold" FontSize="14" FontWeight="Bold" Margin="0,5,0,0"/>
                        <TextBlock x:Name="txtDescription" TextWrapping="Wrap" Margin="0,10,0,0" FontSize="13"/>
                        <WrapPanel Margin="0,15,0,0">
                            <Button x:Name="btnRead" Content="Читать" Style="{StaticResource PrimaryButton}" Width="80" Height="30" Margin="0,0,10,0" Click="BtnRead_Click"/>
                            <Button x:Name="btnAddToList" Content="В список" Style="{StaticResource PrimaryButton}" Width="80" Height="30" Margin="0,0,10,0" Click="BtnAddToList_Click"/>
                            <Button x:Name="btnComplainBook" Content="Жалоба" Style="{StaticResource PrimaryButton}" Width="70" Height="30" Margin="0,0,10,0" Click="BtnComplainBook_Click"/>
                            <Button x:Name="btnFreeze" Content="Заморозить" Style="{StaticResource DangerButton}" Width="90" Height="30" Visibility="Collapsed" Click="BtnFreeze_Click"/>
                        </WrapPanel>
                    </StackPanel>
                </Grid>
            </Border>

            <Border Background="White" CornerRadius="10" Padding="20">
                <StackPanel>
                    <TextBlock Text="Отзывы" FontSize="16" FontWeight="Bold" Margin="0,0,0,10"/>

                    <Border Background="#F5F5F5" Padding="15" CornerRadius="8" Margin="0,0,0,15">
                        <StackPanel>
                            <WrapPanel>
                                <TextBlock Text="Оценка:" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <ComboBox x:Name="cmbRating" Width="80" Height="28">
                                    <ComboBoxItem>5</ComboBoxItem>
                                    <ComboBoxItem>4</ComboBoxItem>
                                    <ComboBoxItem>3</ComboBoxItem>
                                    <ComboBoxItem>2</ComboBoxItem>
                                    <ComboBoxItem>1</ComboBoxItem>
                                </ComboBox>
                            </WrapPanel>
                            <TextBox x:Name="txtReview" Height="60" TextWrapping="Wrap" Margin="0,10,0,0"/>
                            <Button x:Name="btnSubmitReview" Content="Отправить" Style="{StaticResource PrimaryButton}" Width="100" Height="30" Margin="0,10,0,0" Click="BtnSubmitReview_Click"/>
                        </StackPanel>
                    </Border>

                    <ItemsControl x:Name="reviewsList">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="#F5F5F5" Padding="12" CornerRadius="8" Margin="0,0,0,8">
                                    <StackPanel>
                                        <WrapPanel>
                                            <TextBlock Text="{Binding UserName}" FontWeight="Bold"/>
                                            <TextBlock Text=" ★ " Foreground="Gold"/>
                                            <TextBlock Text="{Binding Rating}"/>
                                            <Button Content="⚠️" Width="25" Margin="15,0,0,0" ToolTip="Пожаловаться" Click="BtnComplainReview_Click" Tag="{Binding ReviewId}" Background="Transparent" BorderThickness="0"/>
                                            <Button x:Name="btnFreezeReview" Content="❄️" Width="25" Margin="5,0,0,0" ToolTip="Заморозить" Visibility="Collapsed" Click="BtnFreezeReview_Click" Tag="{Binding ReviewId}" Background="Transparent" BorderThickness="0"/>
                                        </WrapPanel>
                                        <TextBlock Text="{Binding Content}" TextWrapping="Wrap" Margin="0,8,0,0"/>
                                        <TextBlock Text="{Binding CreatedAt, StringFormat=dd.MM.yyyy}" FontSize="10" Foreground="Gray" Margin="0,5,0,0"/>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Page>
