<Page x:Class="OnlineLibrary.Views.UserListsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:OnlineLibrary.Views"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="UserListsPage" Background="White">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <TabControl x:Name="tabLists" Height="40" Margin="0,0,0,15" SelectionChanged="Tab_Changed">
            <TabItem Header="📋 В планах" Tag="planned"/>
            <TabItem Header="📖 Читаю" Tag="reading"/>
            <TabItem Header="✅ Прочитано" Tag="completed"/>
            <TabItem Header="❌ Заброшено" Tag="abandoned"/>
        </TabControl>
        <ScrollViewer Grid.Row="1">
            <WrapPanel x:Name="booksPanel"/>
        </ScrollViewer>
    </Grid>
</Page>
