<Page x:Class="OnlineLibrary.Views.FrozenBooksPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:OnlineLibrary.Views"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="FrozenBooksPage" Background="White">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <TextBlock Text="❄️ Замороженные книги" FontSize="20" FontWeight="Bold"/>
        <ItemsControl x:Name="booksList" Grid.Row="1">
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <Border Background="White" Padding="15" CornerRadius="8" Margin="0,5">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="{Binding Title}" FontWeight="Bold"/>
                            <Button Grid.Column="1" Content="Оспорить" Style="{StaticResource PrimaryButton}" Click="BtnAppeal_Click" Tag="{Binding BookId}"/>
                        </Grid>
                    </Border>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>
    </Grid>
</Page>
