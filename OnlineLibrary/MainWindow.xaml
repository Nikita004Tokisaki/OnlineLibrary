<Window x:Class="OnlineLibrary.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:OnlineLibrary"
        mc:Ignorable="d"
        Title="Онлайн библиотека" Height="700" Width="1100"
        WindowStartupLocation="CenterScreen">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="80"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="{StaticResource SidebarColor}">
            <StackPanel Margin="0,20,0,0">
                <Button x:Name="btnProfile" Click="BtnProfile_Click" Style="{StaticResource SidebarButtonStyle}" ToolTip="Профиль" Margin="0,20,0,0">
                    <Image Source="/Resources/Icons/profile.png" Width="32" Height="32"/>
                </Button>
                <Button x:Name="btnCatalog" Click="BtnCatalog_Click" Style="{StaticResource SidebarButtonStyle}" ToolTip="Каталог книг">
                    <Image Source="/Resources/Icons/catalog.png" Width="32" Height="32"/>
                </Button>
                <Button x:Name="btnLists" Click="BtnLists_Click" Style="{StaticResource SidebarButtonStyle}" ToolTip="Списки книг">
                    <Image Source="/Resources/Icons/lists.png" Width="32" Height="32"/>
                </Button>
                <Button x:Name="btnAdmin" Click="BtnAdmin_Click" Style="{StaticResource SidebarButtonStyle}" ToolTip="Администрирование" Visibility="Collapsed">
                    <Image Source="/Resources/Icons/admin.png" Width="32" Height="32"/>
                </Button>
                <Button x:Name="btnAuthorPage" Click="BtnAuthorPage_Click" Style="{StaticResource SidebarButtonStyle}" ToolTip="Страница автора" Visibility="Collapsed">
                    <Image Source="/Resources/Icons/author.png" Width="32" Height="32"/>
                </Button>
                <Border x:Name="warningBorder" Background="{StaticResource DangerColor}" CornerRadius="8" Margin="10,20,10,0" Visibility="Collapsed">
                    <Button x:Name="btnWarning" Click="BtnWarning_Click" Background="Transparent" BorderThickness="0" Width="60" Height="60" ToolTip="Аккаунт заморожен">
                        <Image Source="/Resources/Icons/warning.png" Width="32" Height="32"/>
                    </Button>
                </Border>
            </StackPanel>
        </Border>

        <Frame x:Name="MainFrame" Grid.Column="1" NavigationUIVisibility="Hidden"/>
    </Grid>
</Window>
